# OpenAI API key (required for analysis + embeddings)
OPENAI_API_KEY=sk-your-openai-key-here

# Supabase credentials (required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# CourtListener API token (optional but recommended)
COURTLISTENER_API_TOKEN=your-courtlistener-token-here

# Stripe (required for subscriptions)
# Get these from https://dashboard.stripe.com/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_SECRET_KEY=sk_live_...

# Webhook secret — get from Stripe Dashboard > Webhooks after creating endpoint
# Endpoint URL: https://your-domain.com/api/webhooks/stripe
STRIPE_WEBHOOK_SECRET=whsec_...

# Price ID — create a product+price in Stripe Dashboard > Products
# e.g. $1/month recurring subscription
STRIPE_PRICE_ID=price_...

# Base URL (used for Stripe redirect URLs)
NEXT_PUBLIC_APP_URL=http://localhost:3000
