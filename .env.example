# OpenAI API key (required for analysis + embeddings)
OPENAI_API_KEY=sk-your-openai-key-here

# Supabase credentials (required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# CourtListener API token (optional but recommended — create free account at courtlistener.com)
COURTLISTENER_API_TOKEN=your-courtlistener-token-here

# Stripe (required for subscriptions)
STRIPE_SECRET_KEY=sk_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_...
STRIPE_PRICE_ID=price_...
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase Auth: For signup without email confirmation, go to
# Dashboard → Authentication → Providers → Email → disable "Confirm email"
